# ── LLM providers — cần ÍT NHẤT 1 khoá (llm_router tự chọn theo tác vụ) ──
ANTHROPIC_API_KEY=your_anthropic_api_key_here      # console.anthropic.com
OPENAI_API_KEY=your_openai_api_key_here            # platform.openai.com
GEMINI_API_KEY=your_gemini_api_key_here            # Google AI Studio (grounded search)

# ── Lưu trữ ──────────────────────────────────────────────────────
# Không set gì = SQLite (webapp/markos_web.db) — chạy được ngay.
# Set cả 2 dòng dưới + chạy webapp/supabase_schema.sql = dùng Supabase.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here    # service_role key (NOT anon)

# ── Facebook Ads (tuỳ chọn — chỉ cần cho phần quảng cáo/đo hiệu quả) ──
FB_APP_ID=your_fb_app_id
FB_APP_SECRET=your_fb_app_secret
ENCRYPTION_KEY=your_fernet_key_here                # python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# ── Tuỳ chọn ─────────────────────────────────────────────────────
WEB_DEFAULT_USER_ID=                               # user mặc định khi mở web
PORT=8000
